---
/** Marken-Logo. Pro Instanz eine eindeutige gradientId vergeben (SVG-IDs sind dokumentweit). */
interface Props {
  gradientId?: string;
}
const { gradientId = 'lg-brand' } = Astro.props;
---
<svg viewBox="0 0 32 32" aria-hidden="true">
  <defs>
    <linearGradient id={gradientId} x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="var(--gl-color-primary)"></stop>
      <stop offset="1" stop-color="var(--gl-color-primary-dark)"></stop>
    </linearGradient>
  </defs>
  <rect x="3" y="3" width="26" height="26" rx="9" fill="none" stroke={`url(#${gradientId})`} stroke-width="2.4"></rect>
  <path d="M12 10v12h9" fill="none" stroke={`url(#${gradientId})`} stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"></path>
</svg>
