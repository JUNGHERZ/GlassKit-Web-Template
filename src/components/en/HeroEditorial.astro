---
/**
 * EN-Sprachzweig von HeroEditorial.astro — Alternative zum Showcase-Hero
 * für Dienstleister/Agenturen: typografisch, einspaltig, ohne Device-Panel.
 * Einsatz: in en/index.astro Hero durch HeroEditorial ersetzen.
 * Leistungen, Kennzahlen und Claims sind Platzhalter pro Projekt.
 */
---
<section class="glw-hero glw-hero--editorial">
  <div class="glw-container">
    <span class="glw-eyebrow">LUMEN · IT development &amp; consulting</span>
    <h1 class="glw-display">Digital transformation that <span class="glw-glint">delivers.</span></h1>
    <p class="glw-hero__sub">
      We build custom software and guide companies from process analysis to
      operations — specialising in document management, integrations and
      automation. No buzzwords, just results.
    </p>
    <div class="glw-cta-row">
      <button class="glass-btn glass-btn--primary glass-btn--auto" type="button">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M21 11.5a8.4 8.4 0 0 1-8.5 8.3 8.7 8.7 0 0 1-3.9-.9L3 20l1.2-5.2a8 8 0 0 1-.7-3.3A8.4 8.4 0 0 1 12 3.2a8.4 8.4 0 0 1 9 8.3z"></path></svg>
        Start a project
      </button>
      <button class="glass-btn glass-btn--tertiary glass-btn--auto" type="button">View references</button>
    </div>

    <div class="glw-services" aria-label="Services">
      <span class="glass-badge">Custom development</span>
      <span class="glass-badge">System integration</span>
      <span class="glass-badge">DMS &amp; ECM</span>
      <span class="glass-badge">AI automation</span>
      <span class="glass-badge">Consulting &amp; training</span>
    </div>

    <div class="glw-statline">
      <div><strong>60+</strong><small>projects delivered</small></div>
      <div><strong>15 years</strong><small>development &amp; consulting</small></div>
      <div><strong>&lt; 24 h</strong><small>support response time</small></div>
      <div><strong>100 %</strong><small>hosted in Germany</small></div>
    </div>
  </div>
</section>
