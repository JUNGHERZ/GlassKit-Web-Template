---
/**
 * EN-Sprachzweig von Showcase.astro: perspektivisch gekipptes Glas-Fenster
 * (visionOS-Anmutung) mit Maus-Parallax (site.js, #tiltWindow). Dekorativ.
 */
---
<section class="glw-section" id="showcase">
  <div class="glw-container">
    <div class="glw-center reveal">
      <span class="glw-eyebrow">One language, every platform</span>
      <h2 class="glw-h2">From home screen to spatial computing.</h2>
      <p class="glw-lead">
        Same tokens, same components: the GlassKit design language scales
        from smartphone to desktop to spatial interfaces.
      </p>
    </div>

    <div class="glw-stage reveal">
      <div class="glw-window" id="tiltWindow" aria-hidden="true">
        <div class="glw-window__rail">
          <span class="glass-pill is-active"><svg viewBox="0 0 24 24"><path d="m4 11 8-7 8 7v9a1 1 0 0 1-1 1h-5v-6h-4v6H5a1 1 0 0 1-1-1z"></path></svg></span>
          <span class="glass-pill"><svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"></circle><path d="m21 21-4.3-4.3"></path></svg></span>
          <span class="glass-pill"><svg viewBox="0 0 24 24"><path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z"></path><path d="M14 3v5h5"></path></svg></span>
          <span class="glass-pill"><svg viewBox="0 0 24 24"><path d="M12 20s7-4.3 9-8.5C22.4 8 20.4 5 17.2 5 15.2 5 13.6 6.1 12.8 7.7L12 9l-.8-1.3C10.4 6.1 8.8 5 6.8 5 3.6 5 1.6 8 3 11.5 5 15.7 12 20 12 20z"></path></svg></span>
          <span class="glass-pill"><svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="3.4"></circle><path d="M5.5 20c.8-3.6 3.3-5.5 6.5-5.5s5.7 1.9 6.5 5.5"></path></svg></span>
        </div>

        <div class="glw-window__main">
          <div class="glw-post__head">
            <span class="glw-avatar glw-avatar--teal">JW</span>
            <div>
              <div class="glw-post__name">Jonas Weber</div>
              <div class="glw-post__meta">Accounting · 6 min ago</div>
            </div>
          </div>
          <p class="glw-post__text">
            The quarterly report is final and filed under “Q2 / Approvals”.
            OCR and indexing have finished – full-text search is live.
          </p>
          <div class="glw-media">
            <div class="glw-media__doc">
              <svg viewBox="0 0 64 64"><path d="M18 8h20l8 8v36a4 4 0 0 1-4 4H18a4 4 0 0 1-4-4V12a4 4 0 0 1 4-4z"></path><path d="M38 8v8h8"></path><path d="M24 30h16M24 38h16M24 46h9"></path></svg>
            </div>
            <div class="glw-media__bar">
              <span>Quarterly_Report_Q2.pdf</span>
              <span class="glass-badge glass-badge--success">Approved</span>
            </div>
          </div>
          <div class="glw-post__actions">
            <svg viewBox="0 0 24 24"><path d="M12 20s-7-4.3-9-8.5C1.6 8 3.6 5 6.8 5c2 0 3.6 1.1 4.4 2.7L12 9l.8-1.3C13.6 6.1 15.2 5 17.2 5c3.2 0 5.2 3 3.8 6.5C19 15.7 12 20 12 20z"></path></svg>
            <svg viewBox="0 0 24 24"><path d="M21 11.5a8.4 8.4 0 0 1-9 8.4 8.6 8.6 0 0 1-3.5-.7L3 21l1.8-5.5a8.4 8.4 0 1 1 16.2-4z"></path></svg>
            <svg viewBox="0 0 24 24"><path d="M4 12v7a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1v-7"></path><path d="m16 6-4-4-4 4"></path><path d="M12 2v13"></path></svg>
          </div>
        </div>

        <div class="glw-window__aside">
          <div class="glass-list__section-header">Activity</div>
          <ul class="glass-list glass-list--bare">
            <li class="glass-list__item">
              <div class="glass-list__content"><div class="glass-list__title">Inbox</div></div>
              <div class="glass-list__trailing"><span class="glass-badge glass-badge--primary">12</span></div>
            </li>
            <li class="glass-list__item">
              <div class="glass-list__content"><div class="glass-list__title">Approvals</div></div>
              <div class="glass-list__trailing"><span class="glass-badge">3</span></div>
            </li>
            <li class="glass-list__item">
              <div class="glass-list__content"><div class="glass-list__title">Team</div></div>
              <div class="glass-list__trailing"><span class="glass-badge glass-badge--success">8 online</span></div>
            </li>
          </ul>
        </div>
      </div>

      <div class="glw-platforms">
        <span class="glass-badge">iPhone</span>
        <span class="glass-badge">iPad</span>
        <span class="glass-badge">Web</span>
        <span class="glass-badge glass-badge--primary">Vision Pro</span>
      </div>
    </div>
  </div>
</section>
