---
/**
 * EN-Sprachzweig von Bento.astro: Feature-Raster mit eingebetteten
 * Mini-Visualisierungen in den Media-Slots. Struktur identisch zum
 * DE-Zweig; Details siehe dort.
 */
---
<section class="glw-section" id="toolkit">
  <div class="glw-container">
    <div class="glw-center reveal">
      <span class="glw-eyebrow">More than an archive</span>
      <h2 class="glw-h2">Built for everyday document work.</h2>
      <p class="glw-lead">
        Four situations where LUMEN makes the difference — from automatic
        filing to handing everything to your accountant.
      </p>
    </div>

    <div class="glw-bento reveal">

      <article class="glw-bento__card glw-bento__card--wide">
        <div class="glw-bento__media" aria-hidden="true">
          <span class="glass-badge" style="position:absolute; left:14%; top:22%">Contract</span>
          <span class="glass-badge" style="position:absolute; right:12%; top:30%">Invoice</span>
          <span class="glass-badge" style="position:absolute; left:22%; bottom:18%">Receipt</span>
          <div class="glw-node glw-node--core" style="left:50%; top:50%">
            <span class="glw-node__icon"><svg viewBox="0 0 24 24"><path d="M12 3v3M12 18v3M3 12h3M18 12h3M5.6 5.6l2.1 2.1M16.3 16.3l2.1 2.1M18.4 5.6l-2.1 2.1M7.7 16.3l-2.1 2.1"></path></svg></span>
            <span><b>AI classification</b><small>detects · names · files</small></span>
          </div>
        </div>
        <h3>Files itself</h3>
        <p>
          Every document is recognised, named and placed in the right folder —
          you never maintain a filing structure again.
        </p>
      </article>

      <article class="glw-bento__card glw-bento__card--narrow">
        <div class="glw-bento__media" aria-hidden="true">
          <div class="glw-bento__stack">
            <div class="glw-bento__avatars">
              <span class="glw-avatar">MK</span>
              <span class="glw-avatar glw-avatar--teal">JS</span>
              <span class="glw-avatar">AL</span>
            </div>
            <div class="glass-progress glass-progress--success">
              <div class="glass-progress__header">
                <span class="glass-progress__label">Approvals</span>
                <span class="glass-progress__value">3/4</span>
              </div>
              <div class="glass-progress__track">
                <div class="glass-progress__fill" style="width: 75%"></div>
              </div>
            </div>
          </div>
        </div>
        <h3>Team approvals</h3>
        <p>
          Four-eyes approval for invoices and contracts — who approved what,
          and when, stays traceable.
        </p>
      </article>

      <article class="glw-bento__card glw-bento__card--narrow">
        <div class="glw-bento__media" aria-hidden="true">
          <div class="glw-bento__stack">
            <div class="glass-search">
              <svg class="glass-search__icon" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
              <span class="glass-input">deposit rental contract</span>
            </div>
            <span class="glass-badge glass-badge--success">2 results in 0.3 s</span>
          </div>
        </div>
        <h3>Search the way you think</h3>
        <p>
          Full text instead of file names: OCR makes every scan searchable —
          "deposit" finds the rental contract, not IMG_2041.
        </p>
      </article>

      <article class="glw-bento__card glw-bento__card--wide">
        <div class="glw-bento__media" aria-hidden="true">
          <div class="glw-bento__chain">
            <span class="glass-badge glass-badge--primary">LUMEN</span>
            <svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"></path></svg>
            <span class="glass-badge">DMS</span>
            <svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"></path></svg>
            <span class="glass-badge">Accounting</span>
            <svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"></path></svg>
            <span class="glass-badge">Tax advisor</span>
          </div>
        </div>
        <h3>Flows into your systems</h3>
        <p>
          Export and integrations instead of a dead end: receipts travel in
          batches to your DMS, accounting or straight to the tax advisor.
        </p>
      </article>

    </div>
  </div>
</section>
