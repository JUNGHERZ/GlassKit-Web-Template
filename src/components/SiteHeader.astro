---
import BrandMark from './BrandMark.astro';
import { siteName, href } from '../data/site';
---
<header class="glw-header" id="top">
  <div class="glw-container glw-header__inner">
    <a class="glw-brand" href={href('/#top')} aria-label={`${siteName} – Startseite`}>
      <BrandMark />
      {siteName}
    </a>

    <nav class="glw-nav" aria-label="Hauptnavigation">
      <a href={href('/#features')}>Produkt</a>
      <a href={href('/#showcase')}>Showcase</a>
      <a href={href('/#preise')}>Preise</a>
      <a href={href('/#kontakt')}>Kontakt</a>
    </nav>

    <div class="glw-header__actions">
      <button class="glass-theme-toggle" id="themeToggle" type="button" aria-label="Farbschema wechseln">
        <svg class="icon-moon" viewBox="0 0 24 24" aria-hidden="true"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path></svg>
        <svg class="icon-sun" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="4.4"></circle><path d="M12 2.5v2.4M12 19.1v2.4M4.3 4.3l1.7 1.7M18 18l1.7 1.7M2.5 12h2.4M19.1 12h2.4M4.3 19.7 6 18M18 6l1.7-1.7"></path></svg>
      </button>
      <button class="glass-btn glass-btn--primary glass-btn--sm glass-btn--auto" type="button">
        <span class="only-b2c">Kostenlos starten</span>
        <span class="only-b2b">Demo vereinbaren</span>
      </button>
    </div>
  </div>
</header>
