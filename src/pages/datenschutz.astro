---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteName, href } from '../data/site';
---
<BaseLayout title={`Datenschutz – ${siteName}`} description="Datenschutzerklärung (Platzhalter)">
  <section class="glw-section glw-page">
    <div class="glw-container">
      <span class="glw-eyebrow">Rechtliches</span>
      <h1 class="glw-h2">Datenschutzerklärung</h1>
      <p class="glw-lead">Platzhalter – vor Veröffentlichung durch die echte, projektspezifische Erklärung ersetzen.</p>

      <div class="glass-card glw-prose">
        <h2>Verantwortliche Stelle</h2>
        <p>{siteName} GmbH · Musterstraße 1 · 00000 Musterstadt · hallo@example.de</p>
        <h2>Hosting</h2>
        <p>Diese Website wird statisch ausgeliefert (z.&nbsp;B. GitHub Pages). Beim Abruf werden technisch notwendige Verbindungsdaten (IP-Adresse, Zeitpunkt, abgerufene Ressource) durch den Hoster verarbeitet.</p>
        <h2>Keine Cookies, kein Tracking</h2>
        <p>Dieses Template setzt keine Cookies und bindet keine Analyse- oder Drittdienste ein. Die Theme- und Zielgruppen-Wahl wird nicht gespeichert.</p>
        <h2>Ihre Rechte</h2>
        <p>Auskunft, Berichtigung, Löschung, Einschränkung, Datenübertragbarkeit, Widerspruch sowie Beschwerde bei einer Aufsichtsbehörde gemäß DSGVO.</p>
      </div>

      <div class="glw-page__back">
        <a class="glass-btn glass-btn--tertiary glass-btn--sm glass-btn--auto" href={href('/')}>← Zurück zur Startseite</a>
      </div>
    </div>
  </section>
</BaseLayout>
